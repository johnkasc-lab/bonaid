# Copy this file to .env and fill in real values. Never commit the real .env.

ENVIRONMENT=development
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bonaid
POSTGRES_USER=bonaid
POSTGRES_PASSWORD=bonaid_dev_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:7b

# --- Reddit OAuth (used by the Sentiment Agent, free - see README) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=

# --- FRED (macro/economic data, used by the Macro Agent, free - see README) ---
FRED_API_KEY=

# --- Notifications (optional, used by later phases) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
ALERTS_ENABLED=true

# --- Broker (optional, used by later phases) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
