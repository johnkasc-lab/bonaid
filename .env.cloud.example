# .env.cloud - copy this to .env.cloud (yes, that exact name) and fill in
# real values. Used by docker-compose.cloud.yml. Your original .env for
# local mode is untouched and still works with docker/docker-compose.yml.

ENVIRONMENT=production
LOG_LEVEL=INFO

# --- PostgreSQL (Supabase/Neon/Railway - get these from your provider's
# connection details page after creating a free project) ---
#
# SUPABASE USERS: use the "Session pooler" connection string, NOT "Direct
# connection". Supabase's direct-connection hostname (db.<project>.supabase.co)
# resolves to IPv6 only, which most Docker Desktop/WSL2 setups can't route
# to ("Network unreachable" errors). The Session Pooler uses a different
# hostname (aws-0-<region>.pooler.supabase.com, port 5432) that resolves
# over IPv4 and works correctly from Docker. Find it in Supabase under
# Project Settings -> Database -> Connection String -> "Session pooler" tab.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require

# --- Redis (optional in cloud mode - leave blank to run without caching,
# everything degrades gracefully without it. If you want caching, Upstash
# has a free Redis tier: https://upstash.com) ---
REDIS_HOST=
REDIS_PORT=6379

# --- Dashboard authentication (REQUIRED before this is reachable
# publicly - pick your own username/password) ---
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

# --- Everything else: same as your local .env - copy these values over ---
OLLAMA_HOST=
OLLAMA_MODEL=qwen2.5:1.5b
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=
ALERTS_ENABLED=true
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
FRED_API_KEY=
